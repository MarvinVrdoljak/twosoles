# ── Supabase ─────────────────────────────────────────────────────────────────
# Copy to .env.local for local dev (values are pre-filled there for the local
# stack). For production on Vercel, set these to your hosted project's values
# from the Supabase dashboard (Project Settings → API):
#
#   Local  → http://127.0.0.1:54321 + the local anon key (see supabase status)
#   Live   → https://<project-ref>.supabase.co + the project's anon (public) key
#
# Only NEXT_PUBLIC_* values are exposed to the browser; the anon key is meant to
# be public and is protected by Row Level Security on the database.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
